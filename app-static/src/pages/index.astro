---
import Base from "../layouts/Base.astro";

const title = "EasyHunt — Every Tech Job in India, One Feed";
const description = "EasyHunt aggregates LinkedIn, Naukri, and Indeed into one unified, filterable job feed for Indian software engineers.";
const siteUrl = "https://easyhunt.space";

const jsonLdApp = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "EasyHunt",
  description,
  url: siteUrl,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "INR" },
  audience: { "@type": "Audience", audienceType: "Software Engineers, Tech Professionals" },
});

const jsonLdOrg = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "EasyHunt",
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  description,
});

const jsonLdFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How does EasyHunt work?",
      acceptedAnswer: { "@type": "Answer", text: "EasyHunt scrapes LinkedIn, Naukri, and Indeed every 4 hours and presents all listings in one unified, deduplicated feed. You can filter by location, salary, work mode, and source." }
    },
    {
      "@type": "Question",
      name: "Is EasyHunt free to use?",
      acceptedAnswer: { "@type": "Answer", text: "Yes. EasyHunt is completely free with no premium tiers, no ads, no sponsored results, and no sign-up required." }
    },
    {
      "@type": "Question",
      name: "Which job boards does EasyHunt aggregate?",
      acceptedAnswer: { "@type": "Answer", text: "EasyHunt aggregates jobs from LinkedIn, Naukri, and Indeed — the three largest job platforms in India, covering 14,000+ new listings every day." }
    },
    {
      "@type": "Question",
      name: "How often are job listings updated?",
      acceptedAnswer: { "@type": "Answer", text: "Job listings are refreshed every 4 hours, ensuring you see the freshest opportunities before they fill up." }
    },
    {
      "@type": "Question",
      name: "Can I track my job applications on EasyHunt?",
      acceptedAnswer: { "@type": "Answer", text: "Yes. EasyHunt includes a built-in application tracker. Save jobs and move them through stages — Saved, Applied, Interviewing, Offered — so you always know where you stand." }
    },
  ],
});
---

<Base {title} {description}>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLdApp} />
    <script type="application/ld+json" set:html={jsonLdOrg} />
    <script type="application/ld+json" set:html={jsonLdFaq} />
  </Fragment>

  <main class="wrap">

    <!-- HERO -->
    <section class="hero" aria-label="Hero">
      <div class="hero-left">
        <div class="hero-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
          Free forever · No ads · No sign-up needed
        </div>
        <h1>Stop switching<br />between <em>portals</em></h1>
        <p class="hero-desc">LinkedIn, Naukri, and Indeed in one clean feed. Filter, save, and track every application — without juggling three tabs.</p>
        <div class="hero-btns">
          <a href="https://app.easyhunt.space/" class="btn-fill">Start searching →</a>
          <a href="#how" class="btn-ghost">How it works</a>
        </div>
      </div>

      <div class="hero-right" aria-hidden="true">
        <div class="float-card">
          <div class="fc-row">
            <span class="fc-title">Senior Backend Engineer</span>
            <span class="fc-badge li">LinkedIn</span>
          </div>
          <div class="fc-salary">Razorpay · Bengaluru</div>
          <div class="fc-divider"></div>
          <div class="fc-bottom">
            <span class="fc-meta">₹32–48 LPA · 2h ago</span>
            <span class="fc-action">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
              Save
            </span>
          </div>
        </div>
        <div class="float-card">
          <div class="fc-row">
            <span class="fc-title">Staff SDE — Payments</span>
            <span class="fc-badge nk">Naukri</span>
          </div>
          <div class="fc-salary">PhonePe · Remote</div>
          <div class="fc-divider"></div>
          <div class="fc-bottom">
            <span class="fc-meta">₹45–65 LPA · 3h ago</span>
          </div>
        </div>
        <div class="float-card">
          <div class="fc-row">
            <span class="fc-title">Platform Engineer</span>
            <span class="fc-badge in">Indeed</span>
          </div>
          <div class="fc-salary">Flipkart · Bengaluru</div>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features" id="features" aria-labelledby="features-heading">
      <div class="sec-hd">
        <span class="sec-tag">Features</span>
        <h2 id="features-heading">Built for engineers<br />who value <em>their time</em></h2>
        <p class="sec-sub">No noise. Every feature exists to get you to the right job, faster.</p>
      </div>

      <div class="f-grid">
        <div class="f-card">
          <div class="f-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>
          </div>
          <h3>Unified Feed</h3>
          <p>Three platforms, one scroll. Deduplicated, sorted by freshness, updated every 4 hours.</p>
        </div>
        <div class="f-card">
          <div class="f-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="16" x2="16" y1="18" y2="22"/></svg>
          </div>
          <h3>Smart Filters</h3>
          <p>Source, location, work mode, salary, role type — all at once. Instant results, no page reloads.</p>
        </div>
        <div class="f-card">
          <div class="f-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 5v11"/><path d="M12 5v6"/><path d="M18 5v14"/><rect width="4" height="5" x="4" y="14" rx="1"/><rect width="4" height="6" x="10" y="9" rx="1"/><rect width="4" height="4" x="16" y="17" rx="1"/></svg>
          </div>
          <h3>Track Applications</h3>
          <p>Saved → Applied → Interviewing → Offered. A simple pipeline that replaces your spreadsheet.</p>
        </div>
        <div class="f-card">
          <div class="f-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
          </div>
          <h3>4-Hour Refresh</h3>
          <p>We scrape continuously. See listings before they fill up. First movers get the best roles.</p>
        </div>
        <div class="f-card">
          <div class="f-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
          </div>
          <h3>Save & Compare</h3>
          <p>Bookmark roles. Revisit, compare, decide at your own pace — no browser tab chaos.</p>
        </div>
        <div class="f-card">
          <div class="f-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg>
          </div>
          <p>No premium tiers, no ads, no sponsored results. Pure, honest job search.</p>
        </div>
      </div>
    </section>

    <!-- SOURCES -->
    <section class="sources" id="sources" aria-labelledby="sources-heading">
      <div class="sources-card">
        <div class="sources-top">
          <div>
            <span class="sec-tag">Where we look</span>
            <h2 id="sources-heading">Every platform.<br /><em>One place.</em></h2>
          </div>
          <div class="sources-total">
            <div class="sources-total-num">14<span>k+</span></div>
            <div class="sources-total-label">jobs indexed every day</div>
          </div>
        </div>
        <div class="sources-platforms">
          <div class="sp-item">
            <div class="sp-dot"></div>
            <div class="sp-name">LinkedIn</div>
            <div class="sp-desc">The world's largest professional network. Strong signal for senior tech roles and MNC postings.</div>
            <div class="sp-stat">4,200+</div>
            <div class="sp-stat-label">tech roles / day</div>
          </div>
          <div class="sp-item">
            <div class="sp-dot"></div>
            <div class="sp-name">Naukri</div>
            <div class="sp-desc">India's dominant board. Unmatched depth in domestic IT firms, product startups, and mid-market companies.</div>
            <div class="sp-stat">6,800+</div>
            <div class="sp-stat-label">listings / day</div>
          </div>
          <div class="sp-item">
            <div class="sp-dot"></div>
            <div class="sp-name">Indeed</div>
            <div class="sp-desc">Global reach, strong India presence. Ideal for remote-first and cross-border opportunities.</div>
            <div class="sp-stat">3,100+</div>
            <div class="sp-stat-label">aggregated / day</div>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS / ACCORDION -->
    <section class="how" id="how" aria-labelledby="how-heading">
      <div class="how-grid">
        <div>
          <span class="sec-tag">How it works</span>
          <h2 id="how-heading">Four steps to<br />your <em>next role</em></h2>
          <p class="sec-sub" style="margin-inline:0;">From discovery to offer — a focused, manageable process.</p>

          <div class="acc-list">
            <div class="acc-item open">
              <button class="acc-btn" data-acc>
                <span class="acc-num">01</span>
                <span class="acc-label">Browse the unified feed</span>
                <svg class="acc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <div class="acc-body">
                <div class="acc-content">Open EasyHunt and see fresh listings from LinkedIn, Naukri, and Indeed — sorted by recency, fully deduplicated.</div>
              </div>
            </div>
            <div class="acc-item">
              <button class="acc-btn" data-acc>
                <span class="acc-num">02</span>
                <span class="acc-label">Filter to your criteria</span>
                <svg class="acc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <div class="acc-body">
                <div class="acc-content">Set your location, salary range, work mode, and source preferences. The feed narrows to exactly what fits your life.</div>
              </div>
            </div>
            <div class="acc-item">
              <button class="acc-btn" data-acc>
                <span class="acc-num">03</span>
                <span class="acc-label">Save your best matches</span>
                <svg class="acc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <div class="acc-body">
                <div class="acc-content">Bookmark roles you want to pursue. They land in your personal list — organized, never lost in browser tabs.</div>
              </div>
            </div>
            <div class="acc-item">
              <button class="acc-btn" data-acc>
                <span class="acc-num">04</span>
                <span class="acc-label">Track every application</span>
                <svg class="acc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <div class="acc-body">
                <div class="acc-content">Move saved jobs through your pipeline as you progress. Know exactly where you stand in every active application.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="pipe-visual">
          <div class="pipe-stage">
            <span class="pipe-dot pd-saved"></span>
            <span class="pipe-label">Saved</span>
            <span class="pipe-badge">12 jobs</span>
          </div>
          <div class="pipe-stage">
            <span class="pipe-dot pd-applied"></span>
            <span class="pipe-label">Applied</span>
            <span class="pipe-badge">5 jobs</span>
          </div>
          <div class="pipe-stage">
            <span class="pipe-dot pd-int"></span>
            <span class="pipe-label">Interviewing</span>
            <span class="pipe-badge">2 jobs</span>
          </div>
          <div class="pipe-stage">
            <span class="pipe-dot pd-offered"></span>
            <span class="pipe-label">Offered</span>
            <span class="pipe-badge">1 job</span>
          </div>
          <div class="pipe-stage">
            <span class="pipe-dot pd-rejected"></span>
            <span class="pipe-label">Rejected / Closed</span>
            <span class="pipe-badge">3 jobs</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta">
      <div class="cta-card">
        <h2>Ready to simplify<br /><em>your search?</em></h2>
        <p>Every tech job in India. One feed. Zero cost.</p>
        <a href="https://app.easyhunt.space/" class="btn-fill" style="position:relative;">Get started for free →</a>
      </div>
    </section>

  </main>

</Base>
