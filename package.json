{
  "name": "easy-hunt",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "app-web",
    "app-api"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\""
  },
  "devDependencies": {
    "prettier": "^3",
    "turbo": "^2"
  }
}
