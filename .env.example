# ─── app-api ──────────────────────────────────────────────────────────────────
# CockroachDB Serverless (postgresql://user:pass@host:26257/defaultdb?sslmode=verify-full)
DATABASE_URL=

# Standard PostgreSQL for pg-boss queue (Neon, Supabase, or local postgres)
# Cannot be CockroachDB — pg-boss uses PARTITION BY LIST which CockroachDB doesn't support
PGBOSS_DATABASE_URL=

# Clerk — from clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_
CLERK_PUBLISHABLE_KEY=pk_test_

# Admin key for /api/v1/admin/* routes (any secret string)
ADMIN_KEY=

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── app-web ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
